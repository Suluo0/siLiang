# 数据库配置
DATABASE_URL="postgres://postgres:YOUR_DB_PASSWORD@localhost:5432/topic"

# API 配置 — DeepSeek (OpenAI-compatible)
TS_DS_APIKEY="sk-your-deepseek-api-key"
API_ADDRESS="https://api.deepseek.com/v1"
API_MODEL="deepseek-chat"

# HuggingFace 镜像（加速模型下载，可选）
HF_ENDPOINT="https://hf-mirror.com"

# RabbitMQ 配置
RABBITMQ_HOST="localhost"
RABBITMQ_PORT=5672
RABBITMQ_USERNAME="guest"
RABBITMQ_PASSWORD="guest"
RABBITMQ_VHOST="/"
RABBITMQ_QUEUE_NAME="topic_tasks"
RABBITMQ_EXCHANGE_NAME="topic_exchange"

# JWT 配置（待启用）
# JWT_SECRET="your-jwt-secret"
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_USER="your-email@gmail.com"
# SMTP_PASSWORD="your-app-password"
