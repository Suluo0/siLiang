# 测试环境变量模板
# 用法:cp .env.test.example .env.test  然后填真实值
# 跑测试前:export $(cat .env.test | xargs)  或者  set -a && source .env.test && set +a

# 测试 PG 库（必须含 'test' 字样,conftest.py 有防呆）
TEST_DATABASE_URL=postgres://postgres:***@localhost:5432/topic_test

# Mock 的外部服务
TS_DS_APIKEY=test-mock-key
API_ADDRESS=https://mock.local
API_MODEL=mock-model
JWT_SECRET=test-jwt-secret-32chars-minimum-aaaa
SMTP_USER=
SMTP_PASS=

# Milvus 测试用(本地不需要时,Phase 4 会用 marker 跳过涉及 Milvus 的测试)
TEST_MILVUS_HOST=localhost
TEST_MILVUS_PORT=19530
