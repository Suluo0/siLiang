# TopicSystem 生产环境变量模板
# 复制为 .env 后填入真实值

# JWT 配置 — 务必更换为强随机密钥
# 生成方式: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET="change-me-use-secrets-token-urlsafe-32"

# 数据库 (使用 app 角色, 非 admin) — 务必更换密码
DATABASE_URL="postgres://topic_app:CHANGE_ME_DB_PASSWORD@postgres:5432/topic"

# DeepSeek API
TS_DS_APIKEY="sk-your-deepseek-api-key"
API_ADDRESS="https://api.deepseek.com/v1"
API_MODEL="deepseek-chat"

# Milvus
MILVUS_HOST="milvus"
MILVUS_PORT=19530

# 可选: SMTP
SMTP_USER=""
SMTP_PASS=""
