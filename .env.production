# TopicSystem 生产环境变量模板
# 复制为 .env 后填入真实值

# 数据库 (使用 app 角色, 非 admin)
DATABASE_URL="postgres://topic_app:Top1cApp#2026@postgres:5432/topic"

# DeepSeek API
TS_DS_APIKEY="sk-your-deepseek-api-key"
API_ADDRESS="https://api.deepseek.com/v1"
API_MODEL="deepseek-chat"

# Milvus
MILVUS_HOST="milvus"
MILVUS_PORT=19530

# 可选: SMTP
SMTP_USER=""
SMTP_PASS=""
